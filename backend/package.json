{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "migrate:list": "npx knex migrate:list --knexfile src/database/knexfile.ts",
    "migrate:up": "npx knex migrate:up --knexfile src/database/knexfile.ts",
    "migrate:down": "npx knex migrate:down --knexfile src/database/knexfile.ts",
    "migrate:rollback": "npx knex migrate:rollback --knexfile src/database/knexfile.ts",
    "migrate:latest": "npx knex migrate:latest --knexfile src/database/knexfile.ts",
    "migrate:make": "npx knex migrate:make create_user_table -x ts --knexfile src/database/knexfile.ts",
    "migrate:status": "npx knex migrate:status --knexfile src/database/knexfile.ts",
    "dev": "nodemon --exec ts-node-dev --project tsconfig.json -r tsconfig-paths/register --files src/index.ts",
    "build": "tsc && tsc-alias && copyfiles -u 1 src/emails/**/* dist/backend/src",
    "start": "node dist/backend/src/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.1",
    "@types/pdfkit": "^0.17.6",
    "copyfiles": "^2.4.1",
    "nodemon": "^3.1.7",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@expense-tracker/shared": "*",
    "@types/cors": "^2.8.19",
    "bcrypt": "^5.1.1",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "juice": "^11.1.1",
    "knex": "^3.1.0",
    "multer": "^1.4.5-lts.2",
    "multer-storage-cloudinary": "^4.0.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.13.1",
    "resend": "^6.10.0"
  }
}
