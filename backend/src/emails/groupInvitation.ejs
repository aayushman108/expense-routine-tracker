<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Group Invitation - SyncSplit</title>
    <style>
      body {
        background-color: #ffffff;
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica,
          Arial, sans-serif;
        margin: 0;
        padding: 40px 20px;
        -webkit-font-smoothing: antialiased;
        color: #1a1a1a;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
      }
      .logo {
        font-size: 20px;
        font-weight: 700;
        color: #000000;
        letter-spacing: -0.02em;
        text-decoration: none;
        display: block;
        margin-bottom: 48px;
      }
      h1 {
        font-size: 24px;
        font-weight: 600;
        margin: 0 0 24px;
        letter-spacing: -0.01em;
      }
      p {
        margin: 0 0 20px;
        font-size: 16px;
        line-height: 1.6;
        color: #444444;
      }
      .group-details {
        margin: 32px 0;
        border-left: 3px solid #000000;
        padding-left: 20px;
      }
      .group-name {
        font-size: 18px;
        font-weight: 600;
        color: #000000;
        margin-bottom: 4px;
      }
      .inviter {
        font-size: 14px;
        color: #888888;
      }
      .button-container {
        margin: 40px 0;
      }
      .button {
        display: inline-block;
        padding: 14px 28px;
        background-color: #000000;
        color: #ffffff !important;
        text-decoration: none;
        border-radius: 8px;
        font-weight: 500;
        font-size: 16px;
      }
      .divider {
        margin: 40px 0;
        border-top: 1px solid #eeeeee;
      }
      .footer {
        font-size: 13px;
        color: #888888;
        line-height: 1.5;
      }
      .footer p {
        font-size: 13px;
        color: #888888;
        margin: 4px 0;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="logo">SyncSplit</div>

      <h1>Join the group</h1>

      <p>Hello,</p>
      <p>
        You have been invited to join a group on <strong>SyncSplit</strong> to
        track shared expenses together.
      </p>

      <div class="group-details">
        <div class="group-name"><%= groupName %></div>
        <div class="inviter">Invited by <%= adminName %></div>
      </div>

      <div class="button-container">
        <a href="<%= inviteLink %>" class="button">Join Group</a>
      </div>

      <p style="font-size: 14px; color: #888888">
        If you don't have an account, you will be asked to create one first.
      </p>

      <div class="divider"></div>

      <div class="footer">
        <p>SyncSplit Protocol — Precision Financial Tracking</p>
        <p>© 2026 All rights reserved.</p>
      </div>
    </div>
  </body>
</html>
