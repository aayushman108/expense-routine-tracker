DATABASE_URL=database_url

NODE_ENV='development'

PORT=8000

# Cloudinary
CLOUD_NAME=cloud_name
CLOUD_SECRET_KEY=secret_key
CLOUD_AVATAR_FOLDER=user_avatars
CLOUD_API_KEY=api_key

# JWT
ACCESS_TOKEN_SECRET=access_token_secret
REFRESH_TOKEN_SECRET=refresh_token_secret

# In min
ACCESS_TOKEN_EXPIRY=1h
# In days
REFRESH_TOKEN_EXPIRY=7d

# Email Verification
EMAIL_VERIFICATION_SECRET=email_verification_secret
EMAIL_VERIFICATION_TOKEN_EXPIRY=10m

FORGOT_PASSWORD_SECRET=forgot_password_secret
FORGOT_PASSWORD_TOKEN_EXPIRY=10m

RESEND_API_KEY=resend_api_key
RESEND_USER=resend_user

FRONTEND_URL=https://example.com

FIREBASE_SERVICE_ACCOUNT_KEY=firebase_service_account_key
FIREBASE_PROJECT_ID=firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase_client_email
FIREBASE_PRIVATE_KEY=firebase_private_key


BACKEND_URL=backend_url

